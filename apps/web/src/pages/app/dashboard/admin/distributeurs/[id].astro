---
import DashboardLayout from "../../../../../layouts/DashboardLayout.astro";
import { requireAdmin } from "../../../../../lib/auth";

const auth = await requireAdmin(Astro.cookies);
if (!auth) return Astro.redirect("/signin");
if (auth.forbidden) return Astro.redirect("/app");

const { supabase, profile } = auth;
const { id } = Astro.params;

// Distributor ophalen
const { data: dist, error: distErr } = await supabase
  .from("distributors")
  .select("id, name, code, contact_name, contact_email, notes, is_active, project_id")
  .eq("id", id)
  .single();

if (distErr || !dist) return Astro.redirect("/app/dashboard/admin/distributeurs");

// Actief seizoen
const { data: activeSeason } = await supabase
  .from("seasons")
  .select("id, year, label")
  .eq("is_active", true)
  .order("year", { ascending: false })
  .limit(1)
  .maybeSingle();

// Alle seizoenen voor selector
const { data: seasons } = await supabase
  .from("seasons")
  .select("id, year, label, is_active")
  .order("year", { ascending: false });

// Seizoen uit URL of actief seizoen
const url = new URL(Astro.request.url);
const seasonParam = url.searchParams.get("season_id");
const currentSeason = seasonParam
  ? (seasons ?? []).find((s: any) => s.id === seasonParam) ?? activeSeason
  : activeSeason;

// Inventory lines voor dit distributor × seizoen
let lines: any[] = [];
if (currentSeason) {
  const { data } = await supabase
    .from("inventory_lines")
    .select(`
      id, category_code, display_label, voorraad, ingekocht, notes, sort_order,
      inventory_adjustments ( id, label, quantity, notes, created_at )
    `)
    .eq("distributor_id", id)
    .eq("season_id", currentSeason.id)
    .order("sort_order")
    .order("category_code");

  lines = data ?? [];
}

// Product varianten voor dropdown (gesorteerd op sort_order)
const { data: variants } = await supabase
  .from("product_variants")
  .select("id, sku_pattern, display_label, color_hex, color_name, has_rootball, size_from_cm, size_to_cm, sort_order")
  .eq("project_id", dist.project_id)
  .order("sort_order");

// Welke codes zijn al aangemaakt voor dit seizoen/distributor?
const usedCodes = new Set(lines.map((l: any) => l.category_code));
const availableVariants = (variants ?? []).filter((v: any) => !usedCodes.has(v.sku_pattern));

// Maak een snel opzoektabel: code → variant info (voor bestaande rijen)
const variantByCode: Record<string, any> = {};
for (const v of (variants ?? [])) {
  variantByCode[v.sku_pattern] = v;
}

// Bereken beschikbaar + restant per rij
function calcRow(line: any) {
  const extra = (line.inventory_adjustments ?? []).reduce(
    (s: number, a: any) => s + (a.quantity ?? 0),
    0
  );
  const beschikbaar = line.voorraad + line.ingekocht + extra;
  return { extra, beschikbaar, restant: beschikbaar };
}

// Kleur dot HTML
function colorDot(hex: string | undefined): string {
  if (!hex) return "";
  return `<span style="display:inline-block;width:10px;height:10px;border-radius:50%;background:${hex};border:1px solid rgba(255,255,255,0.2);margin-right:6px;flex-shrink:0"></span>`;
}
---

<DashboardLayout title={dist.name} userName={profile!.full_name}>
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/app/dashboard/admin/distributeurs">Distributeurs</a>
    <span>›</span>
    <span>{dist.name}</span>
  </div>

  <!-- Header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">{dist.name}</h1>
      {dist.code && <span class="dist-code">{dist.code}</span>}
    </div>
    <div class="header-actions">
      <form method="get" id="seasonForm">
        <select name="season_id" class="season-select" onchange="this.form.submit()">
          {(seasons ?? []).map((s: any) => (
            <option value={s.id} {...(s.id === currentSeason?.id ? { selected: true } : {})}>
              {s.label}{s.is_active ? " (actief)" : ""}
            </option>
          ))}
        </select>
      </form>
    </div>
  </div>

  <!-- Info kaart -->
  <div class="info-card">
    {dist.contact_name && (
      <div class="info-item">
        <span class="info-label">Contactpersoon</span>
        <span class="info-val">{dist.contact_name}</span>
      </div>
    )}
    {dist.contact_email && (
      <div class="info-item">
        <span class="info-label">E-mail</span>
        <a href={"mailto:" + dist.contact_email} class="info-val info-link">{dist.contact_email}</a>
      </div>
    )}
    {dist.notes && (
      <div class="info-item info-item--wide">
        <span class="info-label">Notities</span>
        <span class="info-val">{dist.notes}</span>
      </div>
    )}
    {!dist.is_active && <div class="badge-inactive">Inactief</div>}
  </div>

  {!currentSeason && (
    <div class="alert-info">Geen actief seizoen gevonden.</div>
  )}

  {currentSeason && (
    <div>
      <!-- Tabel header -->
      <div class="table-header">
        <h2 class="section-title">Voorraad — {currentSeason.label}</h2>
        <div class="table-actions">
          {availableVariants.length > 0
            ? <button class="btn-secondary" id="btnAddRow">+ Rij toevoegen</button>
            : <span class="all-added-hint">Alle categorieën toegevoegd ✓</span>
          }
          <button class="btn-primary" id="btnSave">Opslaan</button>
        </div>
      </div>

      <div id="saveMsg" class="save-msg" style="display:none"></div>

      <!-- Inline "Rij toevoegen" form -->
      <div id="addRowForm" class="add-row-form" style="display:none">
        <div class="add-row-inner">
          <select id="variantSelect" class="variant-select">
            {availableVariants.map((v: any) => (
              <option
                value={v.sku_pattern}
                data-label={v.display_label}
                data-color={v.color_hex ?? ""}
              >
                {v.display_label} ({v.sku_pattern})
              </option>
            ))}
          </select>
          <div class="add-row-nums">
            <div class="num-field">
              <label>Voorraad</label>
              <input type="number" id="addVoorraad" value="0" min="0" class="num-input-sm" />
            </div>
            <div class="num-field">
              <label>Ingekocht</label>
              <input type="number" id="addIngekocht" value="0" class="num-input-sm" />
            </div>
          </div>
          <div class="add-row-btns">
            <button class="btn-primary" id="btnConfirmAdd">Toevoegen</button>
            <button class="btn-cancel" id="btnCancelAdd">Annuleren</button>
          </div>
        </div>
      </div>

      <!-- Tabel -->
      <div class="table-wrapper">
        <table class="inv-table" id="invTable">
          <thead>
            <tr>
              <th class="product-col">Product</th>
              <th class="num-col">Voorraad</th>
              <th class="num-col">Ingekocht</th>
              <th class="adj-col">Aanpassingen</th>
              <th class="num-col total-col">Beschikbaar</th>
              <th class="num-col muted-col">Verkocht</th>
              <th class="num-col">Restant</th>
              <th class="act-col"></th>
            </tr>
          </thead>
          <tbody id="invBody">
            {lines.map((line: any) => {
              const { beschikbaar, restant } = calcRow(line);
              const v = variantByCode[line.category_code];
              const colorHex = v?.color_hex ?? "";
              return (
                <tr class="inv-row" data-id={line.id} data-code={line.category_code} data-label={line.display_label ?? line.category_code}>
                  <td class="product-col">
                    <div class="product-cell">
                      {colorHex && <span class="color-dot" style={"background:" + colorHex}></span>}
                      <div>
                        <div class="product-name">{line.display_label ?? line.category_code}</div>
                        <div class="product-code">{line.category_code}</div>
                      </div>
                    </div>
                  </td>
                  <td class="num-col">
                    <input class="cell-input num-input" type="number" value={line.voorraad} data-field="voorraad" min="0" />
                  </td>
                  <td class="num-col">
                    <input class="cell-input num-input" type="number" value={line.ingekocht} data-field="ingekocht" />
                  </td>
                  <td class="adj-col">
                    <div class="adj-badges">
                      {(line.inventory_adjustments ?? []).map((adj: any) => (
                        <span class={adj.quantity >= 0 ? "adj-badge adj-pos" : "adj-badge adj-neg"}>
                          {adj.label}: {adj.quantity > 0 ? "+" : ""}{adj.quantity}
                        </span>
                      ))}
                      <button class="btn-add-adj" data-line-id={line.id} title="Aanpassing toevoegen">+</button>
                    </div>
                  </td>
                  <td class="num-col total-col beschikbaar-cell">{beschikbaar.toLocaleString("nl")}</td>
                  <td class="num-col muted-cell">0</td>
                  <td class="num-col restant-cell">{restant.toLocaleString("nl")}</td>
                  <td class="act-col">
                    <button class="btn-del-row" title="Rij verwijderen">✕</button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {lines.length === 0 && (
        <div class="empty-table" id="emptyMsg">
          {(variants ?? []).length === 0
            ? <>Geen productcategorieën gevonden. <a href="/app/dashboard/admin/rapportage" class="link">Voeg product varianten toe via de Supabase SQL Editor</a>.</>
            : <>Nog geen voorraadregels voor dit seizoen. Klik op <strong>"+ Rij toevoegen"</strong> om te beginnen.</>
          }
        </div>
      )}
    </div>
  )}

  <!-- Modal: aanpassing toevoegen -->
  <div class="modal-overlay" id="adjModal" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <h2>Aanpassing toevoegen</h2>
        <button class="modal-close" id="adjClose">✕</button>
      </div>
      <form id="adjForm" class="modal-form">
        <input type="hidden" id="adjLineId" />
        <div class="form-group">
          <label>Label <span class="required">*</span></label>
          <input type="text" id="adjLabel" required placeholder="bijv. INFLUENCER ACTIE" />
          <span class="form-hint">Wordt automatisch in hoofdletters opgeslagen</span>
        </div>
        <div class="form-group">
          <label>Hoeveelheid <span class="required">*</span></label>
          <input type="number" id="adjQty" required placeholder="-17 of +50" />
          <span class="form-hint">Negatief = uitgegeven / gereserveerd; positief = ontvangen</span>
        </div>
        <div class="form-group">
          <label>Notitie</label>
          <input type="text" id="adjNotes" placeholder="Optioneel" />
        </div>
        <div id="adjError" class="form-error" style="display:none"></div>
        <div class="form-actions">
          <button type="button" class="btn-secondary" id="adjCancel">Annuleren</button>
          <button type="submit" class="btn-primary" id="adjSubmit">Toevoegen</button>
        </div>
      </form>
    </div>
  </div>

  <script is:inline>
    // Configuratie vanuit Astro via data-attribuut (geen define:vars nodig)
  </script>
</DashboardLayout>

<script define:vars={{ distributorId: dist.id, seasonId: currentSeason?.id ?? null }}>
  // ── Inline "Rij toevoegen" form ────────────────────────────────
  var addForm = document.getElementById("addRowForm");
  var btnAdd = document.getElementById("btnAddRow");

  if (btnAdd) {
    btnAdd.addEventListener("click", function() {
      addForm.style.display = "block";
      btnAdd.style.display = "none";
      document.getElementById("addVoorraad").value = "0";
      document.getElementById("addIngekocht").value = "0";
    });
  }

  document.getElementById("btnCancelAdd") && document.getElementById("btnCancelAdd").addEventListener("click", function() {
    addForm.style.display = "none";
    if (btnAdd) btnAdd.style.display = "";
  });

  document.getElementById("btnConfirmAdd") && document.getElementById("btnConfirmAdd").addEventListener("click", function() {
    var sel = document.getElementById("variantSelect");
    if (!sel || !sel.value) return;
    var opt = sel.options[sel.selectedIndex];
    var code = opt.value;
    var label = opt.dataset.label || code;
    var color = opt.dataset.color || "";
    var voorraad = parseInt(document.getElementById("addVoorraad").value) || 0;
    var ingekocht = parseInt(document.getElementById("addIngekocht").value) || 0;
    var beschikbaar = voorraad + ingekocht;

    // Rij aanmaken
    var tbody = document.getElementById("invBody");
    var tr = document.createElement("tr");
    tr.className = "inv-row";
    tr.dataset.id = "";
    tr.dataset.code = code;
    tr.dataset.label = label;

    var colorDot = color
      ? '<span class="color-dot" style="background:' + color + '"></span>'
      : "";

    tr.innerHTML =
      '<td class="product-col"><div class="product-cell">' + colorDot +
        '<div><div class="product-name">' + label + '</div>' +
        '<div class="product-code">' + code + '</div></div></div></td>' +
      '<td class="num-col"><input class="cell-input num-input" type="number" value="' + voorraad + '" data-field="voorraad" min="0" /></td>' +
      '<td class="num-col"><input class="cell-input num-input" type="number" value="' + ingekocht + '" data-field="ingekocht" /></td>' +
      '<td class="adj-col"><div class="adj-badges"><button class="btn-add-adj" title="Sla eerst op" disabled>+</button></div></td>' +
      '<td class="num-col total-col beschikbaar-cell">' + beschikbaar.toLocaleString("nl") + '</td>' +
      '<td class="num-col muted-cell">0</td>' +
      '<td class="num-col restant-cell">' + beschikbaar.toLocaleString("nl") + '</td>' +
      '<td class="act-col"><button class="btn-del-row" title="Rij verwijderen">✕</button></td>';

    tbody.appendChild(tr);
    bindRowEvents(tr);

    // Verwijder de code uit de dropdown
    opt.remove();
    if (sel.options.length === 0) {
      addForm.style.display = "none";
      if (btnAdd) {
        btnAdd.textContent = "Alle categorieën toegevoegd ✓";
        btnAdd.disabled = true;
        btnAdd.className = "all-added-hint";
      }
    } else {
      // Reset en verberg form
      addForm.style.display = "none";
      if (btnAdd) btnAdd.style.display = "";
    }

    // Lege staat verbergen
    var emptyMsg = document.getElementById("emptyMsg");
    if (emptyMsg) emptyMsg.style.display = "none";
  });

  // ── Rij verwijderen ───────────────────────────────────────────
  function bindDelBtn(row) {
    var delBtn = row.querySelector(".btn-del-row");
    if (!delBtn) return;
    delBtn.addEventListener("click", function() {
      if (confirm("Rij verwijderen? Niet-opgeslagen wijzigingen gaan verloren.")) {
        // Categorie terug toevoegen aan dropdown
        var code = row.dataset.code;
        var label = row.dataset.label;
        var sel = document.getElementById("variantSelect");
        if (sel && code) {
          var newOpt = document.createElement("option");
          newOpt.value = code;
          newOpt.dataset.label = label;
          newOpt.textContent = label + " (" + code + ")";
          sel.appendChild(newOpt);
          if (btnAdd) {
            btnAdd.style.display = "";
            btnAdd.disabled = false;
            btnAdd.textContent = "+ Rij toevoegen";
            btnAdd.className = "btn-secondary";
          }
        }
        row.remove();
      }
    });
  }

  // ── Live berekening beschikbaar / restant ─────────────────────
  function recalcRow(row) {
    var voorraad = parseInt(row.querySelector("[data-field='voorraad']").value) || 0;
    var ingekocht = parseInt(row.querySelector("[data-field='ingekocht']").value) || 0;
    var extra = 0;
    row.querySelectorAll(".adj-badge").forEach(function(badge) {
      var m = badge.textContent.match(/([+-]?\d+)$/);
      if (m) extra += parseInt(m[1]);
    });
    var beschikbaar = voorraad + ingekocht + extra;
    row.querySelector(".beschikbaar-cell").textContent = beschikbaar.toLocaleString("nl");
    row.querySelector(".restant-cell").textContent = beschikbaar.toLocaleString("nl");
  }

  function bindRowEvents(row) {
    bindDelBtn(row);
    row.querySelectorAll(".num-input").forEach(function(input) {
      input.addEventListener("input", function() { recalcRow(row); });
    });
    var adjBtn = row.querySelector(".btn-add-adj");
    if (adjBtn) {
      adjBtn.addEventListener("click", function() {
        var lineId = adjBtn.dataset.lineId || "";
        if (!lineId) {
          alert("Sla de rij eerst op voordat je aanpassingen toevoegt.");
          return;
        }
        openAdjModal(lineId);
      });
    }
  }

  // Bind bestaande rijen
  document.querySelectorAll(".inv-row").forEach(function(row) { bindRowEvents(row); });

  // ── Opslaan ───────────────────────────────────────────────────
  document.getElementById("btnSave").addEventListener("click", async function() {
    var btn = this;
    var msg = document.getElementById("saveMsg");
    btn.disabled = true;
    btn.textContent = "Opslaan…";
    msg.style.display = "none";

    var rows = document.querySelectorAll(".inv-row");
    var lines = [];

    rows.forEach(function(row) {
      var code = row.dataset.code || "";
      if (!code) return;
      lines.push({
        id: row.dataset.id || undefined,
        category_code: code,
        display_label: row.dataset.label || code,
        voorraad: parseInt(row.querySelector("[data-field='voorraad']").value) || 0,
        ingekocht: parseInt(row.querySelector("[data-field='ingekocht']").value) || 0,
        sort_order: lines.length,
      });
    });

    if (lines.length === 0) {
      msg.textContent = "Geen rijen om op te slaan.";
      msg.className = "save-msg save-err";
      msg.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Opslaan";
      return;
    }

    try {
      var res = await fetch("/api/distributeurs/" + distributorId + "/save-inventory", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ season_id: seasonId, lines: lines }),
      });
      var json = await res.json();
      if (!res.ok) {
        msg.textContent = json.error || "Opslaan mislukt.";
        msg.className = "save-msg save-err";
      } else {
        msg.textContent = json.saved + " regel(s) opgeslagen.";
        msg.className = "save-msg save-ok";
        setTimeout(function() { window.location.reload(); }, 700);
      }
    } catch (e) {
      msg.textContent = "Netwerkfout.";
      msg.className = "save-msg save-err";
    } finally {
      msg.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Opslaan";
    }
  });

  // ── Aanpassingen modal ────────────────────────────────────────
  function openAdjModal(lineId) {
    document.getElementById("adjLineId").value = lineId;
    document.getElementById("adjLabel").value = "";
    document.getElementById("adjQty").value = "";
    document.getElementById("adjNotes").value = "";
    document.getElementById("adjError").style.display = "none";
    document.getElementById("adjModal").style.display = "flex";
    setTimeout(function() { document.getElementById("adjLabel").focus(); }, 50);
  }

  function closeAdjModal() {
    document.getElementById("adjModal").style.display = "none";
  }

  document.getElementById("adjClose").addEventListener("click", closeAdjModal);
  document.getElementById("adjCancel").addEventListener("click", closeAdjModal);
  document.getElementById("adjModal").addEventListener("click", function(e) {
    if (e.target === document.getElementById("adjModal")) closeAdjModal();
  });

  document.getElementById("adjForm").addEventListener("submit", async function(e) {
    e.preventDefault();
    var lineId = document.getElementById("adjLineId").value;
    var label = document.getElementById("adjLabel").value.trim();
    var qty = parseInt(document.getElementById("adjQty").value);
    var notes = document.getElementById("adjNotes").value.trim();
    var errEl = document.getElementById("adjError");
    var submitBtn = document.getElementById("adjSubmit");

    errEl.style.display = "none";
    submitBtn.disabled = true;
    submitBtn.textContent = "Toevoegen…";

    try {
      var res = await fetch("/api/distributeurs/" + distributorId + "/add-adjustment", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ inventory_line_id: lineId, label: label, quantity: qty, notes: notes || null }),
      });
      var json = await res.json();
      if (!res.ok) {
        errEl.textContent = json.error || "Fout.";
        errEl.style.display = "block";
      } else {
        closeAdjModal();
        window.location.reload();
      }
    } catch (err) {
      errEl.textContent = "Netwerkfout.";
      errEl.style.display = "block";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Toevoegen";
    }
  });
</script>

<style>
  .breadcrumb {
    display: flex; align-items: center; gap: 0.5rem;
    font-size: 0.8rem; color: #6b7280; margin-bottom: 1.25rem;
  }
  .breadcrumb a { color: #9ca3af; text-decoration: none; }
  .breadcrumb a:hover { color: #f9fafb; }

  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap;
  }
  .page-title { font-size: 1.75rem; font-weight: 800; color: #f9fafb; margin: 0 0 0.25rem; }
  .dist-code {
    font-size: 0.8rem; color: #6b7280; font-family: monospace;
    background: #1f2937; padding: 0.15rem 0.5rem; border-radius: 0.3rem;
  }
  .header-actions { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .season-select {
    background: #1f2937; border: 1px solid #374151; border-radius: 0.4rem;
    color: #f9fafb; padding: 0.45rem 0.75rem; font-size: 0.875rem; cursor: pointer;
  }

  .info-card {
    background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem;
    padding: 1.25rem 1.5rem; display: flex; flex-wrap: wrap; gap: 1.5rem; margin-bottom: 2rem;
  }
  .info-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .info-item--wide { flex: 1; min-width: 200px; }
  .info-label { font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  .info-val { font-size: 0.9rem; color: #f9fafb; }
  .info-link { color: #6366f1; text-decoration: none; }
  .info-link:hover { text-decoration: underline; }
  .badge-inactive { align-self: flex-start; font-size: 0.7rem; background: #374151; color: #9ca3af; padding: 0.2rem 0.6rem; border-radius: 999px; }
  .alert-info { background: #1e1b4b; border: 1px solid #6366f133; color: #818cf8; padding: 1rem 1.25rem; border-radius: 0.5rem; }

  .section-title { font-size: 1.1rem; font-weight: 700; color: #f9fafb; margin: 0; }
  .table-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1rem; flex-wrap: wrap; gap: 0.75rem; }
  .table-actions { display: flex; gap: 0.75rem; align-items: center; }
  .all-added-hint { font-size: 0.8rem; color: #10b981; }

  /* Inline toevoeg-form */
  .add-row-form {
    background: #1f2937; border: 1px solid #374151; border-radius: 0.5rem;
    padding: 1rem 1.25rem; margin-bottom: 1rem;
  }
