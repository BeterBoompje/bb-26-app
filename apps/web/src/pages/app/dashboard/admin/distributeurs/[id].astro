---
import DashboardLayout from "../../../../../layouts/DashboardLayout.astro";
import { requireAdmin } from "../../../../../lib/auth";

const auth = await requireAdmin(Astro.cookies);
if (!auth) return Astro.redirect("/signin");
if (auth.forbidden) return Astro.redirect("/app");

const { supabase, profile } = auth;
const { id } = Astro.params;

// Distributor ophalen
const { data: dist, error: distErr } = await supabase
  .from("distributors")
  .select("id, name, code, contact_name, contact_email, notes, is_active, project_id")
  .eq("id", id)
  .single();

if (distErr || !dist) return Astro.redirect("/app/dashboard/admin/distributeurs");

// Actief seizoen
const { data: activeSeason } = await supabase
  .from("seasons")
  .select("id, year, label")
  .eq("is_active", true)
  .order("year", { ascending: false })
  .limit(1)
  .maybeSingle();

// Alle seizoenen voor selector
const { data: seasons } = await supabase
  .from("seasons")
  .select("id, year, label, is_active")
  .order("year", { ascending: false });

// Seizoen uit URL of actief seizoen
const url = new URL(Astro.request.url);
const seasonParam = url.searchParams.get("season_id");
const currentSeason = seasonParam
  ? (seasons ?? []).find((s: any) => s.id === seasonParam) ?? activeSeason
  : activeSeason;

// Inventory lines voor dit distributor × seizoen
let lines: any[] = [];
if (currentSeason) {
  const { data } = await supabase
    .from("inventory_lines")
    .select(`
      id, category_code, display_label, voorraad, ingekocht, notes, sort_order,
      inventory_adjustments ( id, label, quantity, notes, created_at )
    `)
    .eq("distributor_id", id)
    .eq("season_id", currentSeason.id)
    .order("sort_order")
    .order("category_code");

  lines = data ?? [];
}

// Bereken beschikbaar + restant per rij (verkocht=0 totdat Shopify webhook live is)
function calcRow(line: any) {
  const extra = (line.inventory_adjustments ?? []).reduce(
    (s: number, a: any) => s + (a.quantity ?? 0),
    0
  );
  const beschikbaar = line.voorraad + line.ingekocht + extra;
  return { extra, beschikbaar, restant: beschikbaar };
}
---

<DashboardLayout title={dist.name} userName={profile!.full_name}>
  <!-- Breadcrumb -->
  <div class="breadcrumb">
    <a href="/app/dashboard/admin/distributeurs">Distributeurs</a>
    <span>›</span>
    <span>{dist.name}</span>
  </div>

  <!-- Header -->
  <div class="page-header">
    <div>
      <h1 class="page-title">{dist.name}</h1>
      {dist.code && <span class="dist-code">{dist.code}</span>}
    </div>
    <div class="header-actions">
      <!-- Seizoen selector -->
      <form method="get" id="seasonForm">
        <select name="season_id" class="season-select" onchange="this.form.submit()">
          {(seasons ?? []).map((s: any) => (
            <option
              value={s.id}
              {...(s.id === currentSeason?.id ? { selected: true } : {})}
            >
              {s.label}{s.is_active ? " (actief)" : ""}
            </option>
          ))}
        </select>
      </form>
    </div>
  </div>

  <!-- Info kaart -->
  <div class="info-card">
    {dist.contact_name && (
      <div class="info-item">
        <span class="info-label">Contactpersoon</span>
        <span class="info-val">{dist.contact_name}</span>
      </div>
    )}
    {dist.contact_email && (
      <div class="info-item">
        <span class="info-label">E-mail</span>
        <a href={"mailto:" + dist.contact_email} class="info-val info-link">{dist.contact_email}</a>
      </div>
    )}
    {dist.notes && (
      <div class="info-item info-item--wide">
        <span class="info-label">Notities</span>
        <span class="info-val">{dist.notes}</span>
      </div>
    )}
    {!dist.is_active && <div class="badge-inactive">Inactief</div>}
  </div>

  <!-- Geen seizoen beschikbaar -->
  {!currentSeason && (
    <div class="alert-info">Geen actief seizoen gevonden.</div>
  )}

  {currentSeason && (
    <div>
      <!-- Tabel -->
      <div class="table-header">
        <h2 class="section-title">Voorraad — {currentSeason.label}</h2>
        <div class="table-actions">
          <button class="btn-secondary" id="btnAddRow">+ Rij toevoegen</button>
          <button class="btn-primary" id="btnSave">Opslaan</button>
        </div>
      </div>

      <div id="saveMsg" class="save-msg" style="display:none"></div>

      <div class="table-wrapper">
        <table class="inv-table" id="invTable">
          <thead>
            <tr>
              <th>Categorie</th>
              <th>Omschrijving</th>
              <th class="num-col">Voorraad</th>
              <th class="num-col">Ingekocht</th>
              <th class="adj-col">Aanpassingen</th>
              <th class="num-col total-col">Beschikbaar</th>
              <th class="num-col">Verkocht</th>
              <th class="num-col">Restant</th>
              <th class="act-col"></th>
            </tr>
          </thead>
          <tbody id="invBody">
            {lines.map((line: any) => {
              const { extra, beschikbaar, restant } = calcRow(line);
              return (
                <tr class="inv-row" data-id={line.id}>
                  <td>
                    <input class="cell-input code-input" value={line.category_code} data-field="category_code" />
                  </td>
                  <td>
                    <input class="cell-input" value={line.display_label ?? ""} data-field="display_label" placeholder="Omschrijving" />
                  </td>
                  <td class="num-col">
                    <input class="cell-input num-input" type="number" value={line.voorraad} data-field="voorraad" min="0" />
                  </td>
                  <td class="num-col">
                    <input class="cell-input num-input" type="number" value={line.ingekocht} data-field="ingekocht" />
                  </td>
                  <td class="adj-col">
                    <div class="adj-badges">
                      {(line.inventory_adjustments ?? []).map((adj: any) => (
                        <span class={adj.quantity >= 0 ? "adj-badge adj-pos" : "adj-badge adj-neg"}>
                          {adj.label}: {adj.quantity > 0 ? "+" : ""}{adj.quantity}
                        </span>
                      ))}
                      <button class="btn-add-adj" data-line-id={line.id} title="Aanpassing toevoegen">+</button>
                    </div>
                  </td>
                  <td class="num-col total-col beschikbaar-cell">{beschikbaar.toLocaleString("nl")}</td>
                  <td class="num-col muted-cell">0</td>
                  <td class="num-col restant-cell">{restant.toLocaleString("nl")}</td>
                  <td class="act-col">
                    <button class="btn-del-row" title="Rij verwijderen">✕</button>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      <!-- Lege staat -->
      {lines.length === 0 && (
        <div class="empty-table">
          Nog geen voorraadregels. Klik op "+ Rij toevoegen" om te beginnen.
        </div>
      )}
    </div>
  )}

  <!-- Modal: aanpassing toevoegen -->
  <div class="modal-overlay" id="adjModal" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <h2>Aanpassing toevoegen</h2>
        <button class="modal-close" id="adjClose">✕</button>
      </div>
      <form id="adjForm" class="modal-form">
        <input type="hidden" id="adjLineId" />
        <div class="form-group">
          <label>Label <span class="required">*</span></label>
          <input type="text" id="adjLabel" required placeholder="bijv. INFLUENCER ACTIE" />
          <span class="form-hint">Wordt automatisch in hoofdletters opgeslagen</span>
        </div>
        <div class="form-group">
          <label>Hoeveelheid <span class="required">*</span></label>
          <input type="number" id="adjQty" required placeholder="-17 of +50" />
          <span class="form-hint">Negatief = uitgegeven / gereserveerd; positief = ontvangen</span>
        </div>
        <div class="form-group">
          <label>Notitie</label>
          <input type="text" id="adjNotes" placeholder="Optioneel" />
        </div>
        <div id="adjError" class="form-error" style="display:none"></div>
        <div class="form-actions">
          <button type="button" class="btn-secondary" id="adjCancel">Annuleren</button>
          <button type="submit" class="btn-primary" id="adjSubmit">Toevoegen</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script define:vars={{ distributorId: dist.id, seasonId: currentSeason?.id ?? null }}>
  // ── Nieuwe rij toevoegen ───────────────────────────────────────
  document.getElementById("btnAddRow").addEventListener("click", function() {
    const tbody = document.getElementById("invBody");
    const rowCount = tbody.querySelectorAll(".inv-row").length;
    const tr = document.createElement("tr");
    tr.className = "inv-row";
    tr.dataset.id = "";
    tr.innerHTML = [
      '<td><input class="cell-input code-input" data-field="category_code" placeholder="bijv. MET-100-125" /></td>',
      '<td><input class="cell-input" data-field="display_label" placeholder="Omschrijving" /></td>',
      '<td class="num-col"><input class="cell-input num-input" type="number" value="0" data-field="voorraad" min="0" /></td>',
      '<td class="num-col"><input class="cell-input num-input" type="number" value="0" data-field="ingekocht" /></td>',
      '<td class="adj-col"><div class="adj-badges"><button class="btn-add-adj" title="Aanpassing toevoegen" disabled>+</button></div></td>',
      '<td class="num-col total-col beschikbaar-cell">0</td>',
      '<td class="num-col muted-cell">0</td>',
      '<td class="num-col restant-cell">0</td>',
      '<td class="act-col"><button class="btn-del-row" title="Rij verwijderen">✕</button></td>',
    ].join("");
    tbody.appendChild(tr);
    bindRowEvents(tr);
    tr.querySelector(".code-input").focus();
    document.getElementById("invTable").style.removeProperty("display");
    document.querySelector(".empty-table") && (document.querySelector(".empty-table").style.display = "none");
  });

  // ── Rij verwijderen ───────────────────────────────────────────
  function bindDelBtn(row) {
    row.querySelector(".btn-del-row").addEventListener("click", function() {
      if (confirm("Rij verwijderen? Niet-opgeslagen wijzigingen gaan verloren.")) {
        row.remove();
      }
    });
  }

  // ── Live berekening beschikbaar / restant ──────────────────────
  function recalcRow(row) {
    const voorraad = parseInt(row.querySelector("[data-field='voorraad']").value) || 0;
    const ingekocht = parseInt(row.querySelector("[data-field='ingekocht']").value) || 0;
    let extra = 0;
    row.querySelectorAll(".adj-badge").forEach(function(badge) {
      const m = badge.textContent.match(/([+-]?\d+)$/);
      if (m) extra += parseInt(m[1]);
    });
    const beschikbaar = voorraad + ingekocht + extra;
    row.querySelector(".beschikbaar-cell").textContent = beschikbaar.toLocaleString("nl");
    row.querySelector(".restant-cell").textContent = beschikbaar.toLocaleString("nl");
  }

  function bindRowEvents(row) {
    bindDelBtn(row);
    row.querySelectorAll(".num-input").forEach(function(input) {
      input.addEventListener("input", function() { recalcRow(row); });
    });
    const adjBtn = row.querySelector(".btn-add-adj");
    if (adjBtn) {
      adjBtn.addEventListener("click", function() {
        const lineId = adjBtn.dataset.lineId || "";
        if (!lineId) {
          alert("Sla de rij eerst op voordat je aanpassingen toevoegt.");
          return;
        }
        openAdjModal(lineId);
      });
    }
  }

  // Bind existing rows
  document.querySelectorAll(".inv-row").forEach(function(row) { bindRowEvents(row); });

  // ── Opslaan ───────────────────────────────────────────────────
  document.getElementById("btnSave").addEventListener("click", async function() {
    const btn = this;
    const msg = document.getElementById("saveMsg");
    btn.disabled = true;
    btn.textContent = "Opslaan…";
    msg.style.display = "none";

    const rows = document.querySelectorAll(".inv-row");
    const lines = [];
    let valid = true;

    rows.forEach(function(row) {
      const code = row.querySelector("[data-field='category_code']").value.trim();
      if (!code) { valid = false; return; }
      lines.push({
        id: row.dataset.id || undefined,
        category_code: code,
        display_label: row.querySelector("[data-field='display_label']").value.trim() || null,
        voorraad: parseInt(row.querySelector("[data-field='voorraad']").value) || 0,
        ingekocht: parseInt(row.querySelector("[data-field='ingekocht']").value) || 0,
        sort_order: lines.length,
      });
    });

    if (!valid) {
      msg.textContent = "Vul een categoriecode in voor alle rijen.";
      msg.className = "save-msg save-err";
      msg.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Opslaan";
      return;
    }

    if (lines.length === 0) {
      msg.textContent = "Geen rijen om op te slaan.";
      msg.className = "save-msg save-err";
      msg.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Opslaan";
      return;
    }

    try {
      const res = await fetch("/api/distributeurs/" + distributorId + "/save-inventory", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ season_id: seasonId, lines }),
      });
      const json = await res.json();
      if (!res.ok) {
        msg.textContent = json.error || "Opslaan mislukt.";
        msg.className = "save-msg save-err";
      } else {
        msg.textContent = json.saved + " regel(s) opgeslagen.";
        msg.className = "save-msg save-ok";
        // Reload om nieuwe IDs te laden
        setTimeout(function() { window.location.reload(); }, 800);
      }
    } catch (e) {
      msg.textContent = "Netwerkfout.";
      msg.className = "save-msg save-err";
    } finally {
      msg.style.display = "block";
      btn.disabled = false;
      btn.textContent = "Opslaan";
    }
  });

  // ── Aanpassingen modal ────────────────────────────────────────
  var currentLineId = null;

  function openAdjModal(lineId) {
    currentLineId = lineId;
    document.getElementById("adjLineId").value = lineId;
    document.getElementById("adjLabel").value = "";
    document.getElementById("adjQty").value = "";
    document.getElementById("adjNotes").value = "";
    document.getElementById("adjError").style.display = "none";
    document.getElementById("adjModal").style.display = "flex";
    document.getElementById("adjLabel").focus();
  }

  function closeAdjModal() {
    document.getElementById("adjModal").style.display = "none";
    currentLineId = null;
  }

  document.getElementById("adjClose").addEventListener("click", closeAdjModal);
  document.getElementById("adjCancel").addEventListener("click", closeAdjModal);
  document.getElementById("adjModal").addEventListener("click", function(e) {
    if (e.target === document.getElementById("adjModal")) closeAdjModal();
  });

  document.getElementById("adjForm").addEventListener("submit", async function(e) {
    e.preventDefault();
    const lineId = document.getElementById("adjLineId").value;
    const label = document.getElementById("adjLabel").value.trim();
    const qty = parseInt(document.getElementById("adjQty").value);
    const notes = document.getElementById("adjNotes").value.trim();
    const errEl = document.getElementById("adjError");
    const submitBtn = document.getElementById("adjSubmit");

    errEl.style.display = "none";
    submitBtn.disabled = true;
    submitBtn.textContent = "Toevoegen…";

    try {
      const res = await fetch("/api/distributeurs/" + distributorId + "/add-adjustment", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ inventory_line_id: lineId, label, quantity: qty, notes: notes || null }),
      });
      const json = await res.json();
      if (!res.ok) {
        errEl.textContent = json.error || "Fout.";
        errEl.style.display = "block";
      } else {
        closeAdjModal();
        window.location.reload();
      }
    } catch (err) {
      errEl.textContent = "Netwerkfout.";
      errEl.style.display = "block";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Toevoegen";
    }
  });
</script>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8rem;
    color: #6b7280;
    margin-bottom: 1.25rem;
  }
  .breadcrumb a { color: #9ca3af; text-decoration: none; }
  .breadcrumb a:hover { color: #f9fafb; }

  .page-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }
  .page-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: #f9fafb;
    margin: 0 0 0.25rem;
  }
  .dist-code {
    font-size: 0.8rem;
    color: #6b7280;
    font-family: monospace;
    background: #1f2937;
    padding: 0.15rem 0.5rem;
    border-radius: 0.3rem;
  }
  .header-actions { display: flex; align-items: center; gap: 0.75rem; flex-wrap: wrap; }
  .season-select {
    background: #1f2937;
    border: 1px solid #374151;
    border-radius: 0.4rem;
    color: #f9fafb;
    padding: 0.45rem 0.75rem;
    font-size: 0.875rem;
    cursor: pointer;
  }

  .info-card {
    background: #1f2937;
    border: 1px solid #374151;
    border-radius: 0.75rem;
    padding: 1.25rem 1.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .info-item { display: flex; flex-direction: column; gap: 0.2rem; }
  .info-item--wide { flex: 1; min-width: 200px; }
  .info-label { font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 600; }
  .info-val { font-size: 0.9rem; color: #f9fafb; }
  .info-link { color: #6366f1; text-decoration: none; }
  .info-link:hover { text-decoration: underline; }
  .badge-inactive {
    align-self: flex-start;
    font-size: 0.7rem;
    background: #374151;
    color: #9ca3af;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
  }

  .alert-info {
    background: #1e1b4b;
    border: 1px solid #6366f133;
    color: #818cf8;
    padding: 1rem 1.25rem;
    border-radius: 0.5rem;
  }

  .section-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: #f9fafb;
    margin: 0;
  }
  .table-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .table-actions { display: flex; gap: 0.75rem; }

  .save-msg {
    padding: 0.6rem 1rem;
    border-radius: 0.4rem;
    font-size: 0.875rem;
    margin-bottom: 1rem;
  }
  .save-ok { background: #064e3b22; border: 1px solid #10b98133; color: #10b981; }
  .save-err { background: #7f1d1d22; border: 1px solid #ef444433; color: #ef4444; }

  .table-wrapper { overflow-x: auto; }

  .inv-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
  }
  .inv-table th {
    text-align: left;
    padding: 0.6rem 0.75rem;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #6b7280;
    border-bottom: 1px solid #374151;
    white-space: nowrap;
  }
  .inv-table td {
    padding: 0.4rem 0.5rem;
    border-bottom: 1px solid #1f293788;
    vertical-align: middle;
  }
  .inv-table tr:hover td { background: #1f293733; }

  .num-col { text-align: right; width: 90px; }
  .adj-col { min-width: 180px; }
  .act-col { width: 40px; text-align: center; }
  .total-col { color: #10b981; font-weight: 700; }
  .muted-cell { color: #4b5563; }

  .cell-input {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 0.3rem;
    padding: 0.3rem 0.4rem;
    color: #f9fafb;
    font-size: 0.875rem;
    font-family: inherit;
    width: 100%;
    min-width: 0;
    transition: border-color 0.1s, background 0.1s;
  }
  .cell-input:hover { border-color: #374151; background: #111827; }
  .cell-input:focus { border-color: #6366f1; background: #111827; outline: none; }
  .code-input { font-family: monospace; font-size: 0.85rem; }
  .num-input { text-align: right; }

  .adj-badges {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    align-items: center;
  }
  .adj-badge {
    font-size: 0.72rem;
    padding: 0.15rem 0.45rem;
    border-radius: 999px;
    white-space: nowrap;
    font-weight: 600;
  }
  .adj-pos { background: #064e3b44; color: #10b981; border: 1px solid #10b98133; }
  .adj-neg { background: #7f1d1d44; color: #ef4444; border: 1px solid #ef444433; }
  .btn-add-adj {
    background: #374151;
    color: #9ca3af;
    border: none;
    border-radius: 999px;
    width: 1.4rem;
    height: 1.4rem;
    font-size: 0.9rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    flex-shrink: 0;
  }
  .btn-add-adj:hover { background: #4b5563; color: #f9fafb; }
  .btn-add-adj:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-del-row {
    background: none;
    border: none;
    color: #4b5563;
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.2rem;
  }
  .btn-del-row:hover { color: #ef4444; }

  .empty-table {
    text-align: center;
    padding: 3rem 2rem;
    color: #6b7280;
    font-size: 0.875rem;
    border: 1px dashed #374151;
    border-radius: 0.5rem;
  }

  .btn-primary {
    background: #10b981;
    color: #fff;
    border: none;
    border-radius: 0.5rem;
    padding: 0.5rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-primary:hover { background: #059669; }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-secondary {
    background: #374151;
    color: #f9fafb;
    border: none;
    border-radius: 0.5rem;
    padding: 0.5rem 1.1rem;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
  }
  .btn-secondary:hover { background: #4b5563; }

  /* Modal */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 100;
