---
import DashboardLayout from "../../../../../layouts/DashboardLayout.astro";
import { requireAdmin } from "../../../../../lib/auth";

const auth = await requireAdmin(Astro.cookies);
if (!auth) return Astro.redirect("/signin");
if (auth.forbidden) return Astro.redirect("/app");

const { supabase, profile } = auth;

const { data: sp } = await supabase
  .from("staff_profiles")
  .select("project_id")
  .eq("id", profile!.id)
  .single();

const project_id = sp?.project_id ?? null;

let locations: any[] = [];
if (project_id) {
  const { data } = await supabase
    .from("locations")
    .select("id, name, code, city, is_active, is_open, is_sold_out")
    .eq("project_id", project_id)
    .order("name");
  locations = data ?? [];
}
---

<DashboardLayout title="Locaties" userName={profile!.full_name}>
  <div class="page-header">
    <div>
      <h1 class="page-title">Locaties</h1>
      <p class="page-subtitle">Beheer afhaallocaties</p>
    </div>
    <button class="btn-primary" id="btnNieuw">+ Nieuwe locatie</button>
  </div>

  {!project_id && (
    <div class="alert-warning">
      Geen project gekoppeld aan uw account.
    </div>
  )}

  {project_id && locations.length === 0 && (
    <div class="empty-state">
      <p>Nog geen locaties aangemaakt.</p>
      <p class="empty-hint">Klik op "+ Nieuwe locatie" om te beginnen.</p>
    </div>
  )}

  {locations.length > 0 && (
    <div class="table-wrap">
      <table class="loc-table">
        <thead>
          <tr>
            <th class="col-name">Naam</th>
            <th class="col-code">Code</th>
            <th class="col-city">Stad</th>
            <th class="col-status">Actief</th>
            <th class="col-open">Open</th>
            <th class="col-sold">Uitverkocht</th>
            <th class="col-act"></th>
          </tr>
        </thead>
        <tbody>
          {locations.map((loc: any) => (
            <tr data-id={loc.id}>
              <td class="col-name font-bold">{loc.name}</td>
              <td class="col-code"><code class="loc-code">{loc.code}</code></td>
              <td class="col-city muted">{loc.city ?? "—"}</td>
              <td class="col-status">
                <button
                  class={`toggle-btn ${loc.is_active ? "toggle-on" : "toggle-off"}`}
                  data-id={loc.id} data-field="is_active" data-value={String(loc.is_active)}
                >
                  {loc.is_active ? "Ja" : "Nee"}
                </button>
              </td>
              <td class="col-open">
                <button
                  class={`toggle-btn ${loc.is_open ? "toggle-on" : "toggle-off"}`}
                  data-id={loc.id} data-field="is_open" data-value={String(loc.is_open)}
                >
                  {loc.is_open ? "Ja" : "Nee"}
                </button>
              </td>
              <td class="col-sold">
                <button
                  class={`toggle-btn ${loc.is_sold_out ? "toggle-sold" : "toggle-off"}`}
                  data-id={loc.id} data-field="is_sold_out" data-value={String(loc.is_sold_out)}
                >
                  {loc.is_sold_out ? "Ja" : "Nee"}
                </button>
              </td>
              <td class="col-act">
                <button class="btn-edit"
                  data-id={loc.id}
                  data-name={loc.name}
                  data-code={loc.code}
                  data-city={loc.city ?? ""}
                  data-active={String(loc.is_active)}
                >
                  Bewerken
                </button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}

  <!-- Modal: nieuwe / bewerken locatie -->
  <div class="modal-overlay" id="modal" style="display:none">
    <div class="modal">
      <div class="modal-header">
        <h2 id="modalTitle">Nieuwe locatie</h2>
        <button class="modal-close" id="btnClose">✕</button>
      </div>
      <form id="locForm" class="modal-form">
        <input type="hidden" id="editId" />
        <div class="form-group">
          <label>Naam <span class="required">*</span></label>
          <input type="text" id="fName" required placeholder="bijv. Steck Utrecht" />
        </div>
        <div class="form-group">
          <label>Code <span class="required">*</span></label>
          <input type="text" id="fCode" required placeholder="bijv. steck-utrecht" />
          <span class="form-hint">Unieke korte code (kleine letters, koppeltekens toegestaan)</span>
        </div>
        <div class="form-group">
          <label>Stad</label>
          <input type="text" id="fCity" placeholder="bijv. Utrecht" />
        </div>
        <div class="form-group">
          <label>Status</label>
          <select id="fActive">
            <option value="true">Actief</option>
            <option value="false">Inactief</option>
          </select>
        </div>
        <div id="formError" class="form-error" style="display:none"></div>
        <div class="form-actions">
          <button type="button" class="btn-secondary" id="btnCancel">Annuleren</button>
          <button type="submit" class="btn-primary" id="btnSubmit">Opslaan</button>
        </div>
      </form>
    </div>
  </div>
</DashboardLayout>

<script>
  const modal    = document.getElementById("modal");
  const form     = document.getElementById("locForm") as HTMLFormElement;
  const editId   = document.getElementById("editId") as HTMLInputElement;
  const formError = document.getElementById("formError");
  const modalTitle = document.getElementById("modalTitle");

  function openNew() {
    editId.value = "";
    form.reset();
    (document.getElementById("fCode") as HTMLInputElement).disabled = false;
    modalTitle.textContent = "Nieuwe locatie";
    formError.style.display = "none";
    modal.style.display = "flex";
  }

  function openEdit(btn: HTMLButtonElement) {
    editId.value = btn.dataset.id ?? "";
    (document.getElementById("fName") as HTMLInputElement).value = btn.dataset.name ?? "";
    (document.getElementById("fCode") as HTMLInputElement).value = btn.dataset.code ?? "";
    (document.getElementById("fCode") as HTMLInputElement).disabled = true; // code is immutable
    (document.getElementById("fCity") as HTMLInputElement).value = btn.dataset.city ?? "";
    (document.getElementById("fActive") as HTMLSelectElement).value = btn.dataset.active ?? "true";
    modalTitle.textContent = "Locatie bewerken";
    formError.style.display = "none";
    modal.style.display = "flex";
  }

  function closeModal() {
    modal.style.display = "none";
    form.reset();
    (document.getElementById("fCode") as HTMLInputElement).disabled = false;
    formError.style.display = "none";
  }

  document.getElementById("btnNieuw")?.addEventListener("click", openNew);
  document.getElementById("btnClose")?.addEventListener("click", closeModal);
  document.getElementById("btnCancel")?.addEventListener("click", closeModal);
  modal?.addEventListener("click", (e) => { if (e.target === modal) closeModal(); });

  document.querySelectorAll(".btn-edit").forEach((btn) => {
    btn.addEventListener("click", () => openEdit(btn as HTMLButtonElement));
  });

  // Toggle buttons (is_active, is_open, is_sold_out)
  document.querySelectorAll(".toggle-btn").forEach((btn) => {
    btn.addEventListener("click", async () => {
      const b = btn as HTMLButtonElement;
      const id    = b.dataset.id!;
      const field = b.dataset.field!;
      const cur   = b.dataset.value === "true";
      const next  = !cur;

      b.disabled = true;
      try {
        const res = await fetch(`/api/locaties/${id}/update`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ [field]: next }),
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const json = await res.json();
          alert(json.error ?? "Update mislukt.");
        }
      } finally {
        b.disabled = false;
      }
    });
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    formError.style.display = "none";
    const id = editId.value;
    const submitBtn = document.getElementById("btnSubmit") as HTMLButtonElement;
    submitBtn.disabled = true;
    submitBtn.textContent = "Opslaan…";

    const payload: Record<string, unknown> = {
      name:      (document.getElementById("fName") as HTMLInputElement).value.trim(),
      city:      (document.getElementById("fCity") as HTMLInputElement).value.trim() || null,
      is_active: (document.getElementById("fActive") as HTMLSelectElement).value === "true",
    };
    if (!id) {
      payload.code = (document.getElementById("fCode") as HTMLInputElement).value.trim();
    }

    try {
      const url = id ? `/api/locaties/${id}/update` : "/api/locaties/create";
      const res = await fetch(url, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(payload),
      });
      const json = await res.json();
      if (!res.ok) {
        formError.textContent = json.error || "Er ging iets mis.";
        formError.style.display = "block";
      } else {
        window.location.reload();
      }
    } catch {
      formError.textContent = "Netwerkfout.";
      formError.style.display = "block";
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Opslaan";
    }
  });
</script>

<style>
  .page-header {
    display: flex; align-items: flex-start; justify-content: space-between;
    gap: 1rem; margin-bottom: 2rem;
  }
  .page-title { font-size: 1.75rem; font-weight: 800; color: #f9fafb; margin: 0 0 0.25rem; }
  .page-subtitle { color: #9ca3af; font-size: 0.875rem; margin: 0; }

  .btn-primary {
    background: #10b981; color: #fff; border: none; border-radius: 0.5rem;
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600; cursor: pointer; white-space: nowrap;
  }
  .btn-primary:hover { background: #059669; }
  .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }
  .btn-secondary {
    background: #374151; color: #f9fafb; border: none; border-radius: 0.5rem;
    padding: 0.6rem 1.25rem; font-size: 0.875rem; font-weight: 600; cursor: pointer;
  }
  .btn-secondary:hover { background: #4b5563; }

  .alert-warning {
    background: #78350f22; border: 1px solid #f59e0b44; color: #f59e0b;
    padding: 1rem 1.25rem; border-radius: 0.5rem; margin-bottom: 1.5rem;
  }
  .empty-state { text-align: center; padding: 4rem 2rem; color: #9ca3af; }
  .empty-state p { margin: 0 0 0.5rem; }
  .empty-hint { font-size: 0.875rem; }

  .table-wrap { overflow-x: auto; border: 1px solid #374151; border-radius: 0.75rem; }
  .loc-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .loc-table th {
    background: #1f2937; color: #6b7280; font-size: 0.72rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.05em; padding: 0.65rem 1rem;
    text-align: left; border-bottom: 1px solid #374151; white-space: nowrap;
  }
  .loc-table td {
    padding: 0.65rem 1rem; border-bottom: 1px solid #374151;
    color: #e5e7eb; vertical-align: middle;
  }
  .loc-table tr:last-child td { border-bottom: none; }
  .loc-table tr:hover td { background: rgba(255,255,255,0.025); }

  .col-name  { min-width: 160px; }
  .col-code  { width: 140px; }
  .col-city  { width: 120px; }
  .col-status, .col-open, .col-sold { width: 80px; }
  .col-act   { width: 100px; text-align: right; }

  .font-bold { font-weight: 700; color: #f9fafb; }
  .muted { color: #6b7280; font-size: 0.85rem; }

  .loc-code {
    font-family: monospace; font-size: 0.82rem; color: #9ca3af;
    background: #111827; padding: 0.15rem 0.4rem; border-radius: 0.25rem;
  }

  .toggle-btn {
    font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.55rem; border-radius: 999px;
    border: none; cursor: pointer; transition: opacity 0.1s;
  }
  .toggle-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .toggle-on   { background: #064e3b; color: #6ee7b7; }
  .toggle-off  { background: #374151; color: #9ca3af; }
  .toggle-sold { background: #7f1d1d; color: #fca5a5; }

  .btn-edit {
    background: none; border: 1px solid #374151; border-radius: 0.35rem;
    color: #9ca3af; font-size: 0.75rem; padding: 0.25rem 0.6rem; cursor: pointer;
  }
  .btn-edit:hover { background: #1f2937; color: #f9fafb; border-color: #6366f1; }

  /* Modal */
  .modal-overlay {
    position: fixed; inset: 0; background: rgba(0,0,0,0.6);
    display: flex; align-items: center; justify-content: center; z-index: 100;
  }
  .modal {
    background: #1f2937; border: 1px solid #374151; border-radius: 0.75rem;
    padding: 1.75rem; width: 100%; max-width: 420px;
  }
  .modal-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; }
  .modal-header h2 { font-size: 1.2rem; font-weight: 700; color: #f9fafb; margin: 0; }
  .modal-close { background: none; border: none; color: #9ca3af; font-size: 1.1rem; cursor: pointer; }
  .modal-form { display: flex; flex-direction: column; gap: 1rem; }
  .form-group { display: flex; flex-direction: column; gap: 0.3rem; }
  .form-group label { font-size: 0.8rem; font-weight: 600; color: #9ca3af; }
  .form-group input,
  .form-group select {
    background: #111827; border: 1px solid #374151; border-radius: 0.4rem;
    padding: 0.5rem 0.75rem; color: #f9fafb; font-size: 0.9rem; font-family: inherit;
  }
  .form-group select option { background: #111827; }
  .form-group input:focus,
  .form-group select:focus { outline: none; border-color: #6366f1; }
  .form-group input:disabled { opacity: 0.5; cursor: not-allowed; }
  .form-hint { font-size: 0.75rem; color: #6b7280; }
  .required { color: #ef4444; }
  .form-error {
    color: #ef4444; font-size: 0.85rem; background: #7f1d1d22;
    border: 1px solid #ef444433; padding: 0.5rem 0.75rem; border-radius: 0.4rem;
  }
  .form-actions { display: flex; gap: 0.75rem; justify-content: flex-end; margin-top: 0.5rem; }
</style>
